# ──────────────────────────────────────────────
# Jarvis Bot — настройки окружения
# Переименуй этот файл в .env и заполни значения
# ──────────────────────────────────────────────

# 1. Токен Telegram бота
#    Получи у @BotFather в Telegram → /newbot
TELEGRAM_TOKEN=your_telegram_bot_token_here

# 2. API ключ Anthropic (Claude)
#    https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 3. Твой Telegram chat_id (для авто-отчётов)
#    Узнай: напиши @userinfobot в Telegram
TELEGRAM_CHAT_ID=your_chat_id_here

# 4. Как часто делать автоматический анализ (в часах)
#    6 = каждые 6 часов, 24 = раз в сутки
AUTO_ANALYZE_HOURS=6

# 5. (Опционально) HTTP прокси если Etsy блокирует
#    Формат: http://user:pass@host:port
# HTTP_PROXY=
